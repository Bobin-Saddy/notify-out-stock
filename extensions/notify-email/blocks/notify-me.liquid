{% comment %}
  Notify Me Button — Multilanguage support
  File: notify-me-button.liquid
  Flow: Button click → Language picker → Email form → Success
{% endcomment %}

<style>
/* ─── Overlay ─────────────────────────────────────────────── */
.bis-overlay-{{ block.id }} {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(6px);
  display: none;
  z-index: 9998;
}

/* ─── Modal ───────────────────────────────────────────────── */
.bis-modal-{{ block.id }} {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: calc(100% - 32px);
  max-width: 440px;
  background: {{ block.settings.popup_bg_color }};
  color: {{ block.settings.popup_text_color }};
  border-radius: 20px;
  padding: 32px 28px 28px;
  box-shadow: 0 24px 80px rgba(0,0,0,0.3);
  z-index: 9999;
  display: none;
  font-family: {{ block.settings.popup_font }};
  overflow: hidden;
}

/* ─── Steps ───────────────────────────────────────────────── */
.bis-step-{{ block.id }} {
  display: none;
  animation: bisSlideIn 0.28s cubic-bezier(0.34, 1.2, 0.64, 1) forwards;
}
.bis-step-{{ block.id }}.active {
  display: block;
}

@keyframes bisSlideIn {
  from { opacity: 0; transform: translateY(12px) scale(0.97); }
  to   { opacity: 1; transform: translateY(0)    scale(1);    }
}

/* ─── Close button ────────────────────────────────────────── */
.bis-close-{{ block.id }} {
  position: absolute;
  top: 14px;
  right: 16px;
  border: none;
  background: rgba(0,0,0,0.07);
  width: 30px;
  height: 30px;
  border-radius: 50%;
  font-size: 16px;
  cursor: pointer;
  color: {{ block.settings.popup_text_color }};
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  transition: background 0.2s;
}
.bis-close-{{ block.id }}:hover { background: rgba(0,0,0,0.14); }

/* ─── Step header ─────────────────────────────────────────── */
.bis-step-header-{{ block.id }} {
  text-align: center;
  margin-bottom: 22px;
}
.bis-step-header-{{ block.id }} .bis-icon {
  font-size: 36px;
  display: block;
  margin-bottom: 10px;
}
.bis-step-header-{{ block.id }} h3 {
  margin: 0 0 6px;
  font-size: 20px;
  font-weight: 800;
  letter-spacing: -0.3px;
}
.bis-step-header-{{ block.id }} p {
  margin: 0;
  font-size: 13px;
  opacity: 0.65;
  line-height: 1.5;
}

/* ─── Language grid ───────────────────────────────────────── */
.bis-lang-grid-{{ block.id }} {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10px;
  margin-bottom: 6px;
}

.bis-lang-btn-{{ block.id }} {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 14px;
  border: 2px solid transparent;
  border-radius: 12px;
  background: rgba(0,0,0,0.04);
  cursor: pointer;
  transition: all 0.18s;
  font-size: 14px;
  font-weight: 600;
  color: {{ block.settings.popup_text_color }};
  text-align: left;
}

.bis-lang-btn-{{ block.id }}:hover {
  border-color: #667eea;
  background: rgba(102, 126, 234, 0.08);
  transform: translateY(-1px);
}

.bis-lang-btn-{{ block.id }} .bis-flag {
  font-size: 22px;
  line-height: 1;
}

.bis-lang-btn-{{ block.id }} .bis-lang-name {
  font-size: 13px;
  font-weight: 700;
}

.bis-lang-btn-{{ block.id }} .bis-lang-native {
  font-size: 11px;
  opacity: 0.55;
  display: block;
  margin-top: 1px;
}

/* ─── Back button ─────────────────────────────────────────── */
.bis-back-{{ block.id }} {
  display: flex;
  align-items: center;
  gap: 6px;
  border: none;
  background: none;
  cursor: pointer;
  font-size: 13px;
  font-weight: 600;
  color: #667eea;
  padding: 0;
  margin-bottom: 18px;
  opacity: 0.85;
  transition: opacity 0.2s;
}
.bis-back-{{ block.id }}:hover { opacity: 1; }

/* ─── Selected language badge ─────────────────────────────── */
.bis-lang-badge-{{ block.id }} {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: rgba(102,126,234,0.1);
  border: 1px solid rgba(102,126,234,0.25);
  border-radius: 20px;
  padding: 4px 12px 4px 8px;
  font-size: 12px;
  font-weight: 700;
  color: #667eea;
  margin-bottom: 16px;
}

/* ─── Email input ─────────────────────────────────────────── */
.bis-email-{{ block.id }} {
  width: 100%;
  padding: 14px 16px;
  border-radius: 12px;
  border: 2px solid rgba(0,0,0,0.1);
  font-size: 15px;
  margin-bottom: 12px;
  box-sizing: border-box;
  background: rgba(0,0,0,0.03);
  color: {{ block.settings.popup_text_color }};
  transition: border-color 0.2s;
  outline: none;
  font-family: {{ block.settings.popup_font }};
}
.bis-email-{{ block.id }}:focus {
  border-color: #667eea;
  background: white;
}

/* ─── Submit button ───────────────────────────────────────── */
.bis-submit-{{ block.id }} {
  width: 100%;
  padding: 15px;
  border-radius: 12px;
  border: none;
  cursor: pointer;
  font-size: 15px;
  font-weight: 800;
  color: #fff;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  transition: all 0.2s;
  letter-spacing: 0.2px;
  font-family: {{ block.settings.popup_font }};
}
.bis-submit-{{ block.id }}:hover    { opacity: 0.9; transform: translateY(-1px); box-shadow: 0 6px 20px rgba(102,126,234,0.35); }
.bis-submit-{{ block.id }}:disabled { opacity: 0.55; cursor: not-allowed; transform: none; box-shadow: none; }

/* ─── Message ─────────────────────────────────────────────── */
.bis-message-{{ block.id }} {
  margin-top: 12px;
  text-align: center;
  font-size: 13px;
  min-height: 18px;
}
.bis-message-{{ block.id }}.success { color: #10b981; }
.bis-message-{{ block.id }}.error   { color: #ef4444; }

/* ─── Success step ────────────────────────────────────────── */
.bis-success-{{ block.id }} {
  text-align: center;
  padding: 12px 0 4px;
}
.bis-success-{{ block.id }} .bis-success-icon {
  font-size: 52px;
  display: block;
  margin-bottom: 14px;
  animation: bisBounce 0.5s cubic-bezier(0.34,1.5,0.64,1);
}
@keyframes bisBounce {
  from { transform: scale(0.3); opacity: 0; }
  to   { transform: scale(1);   opacity: 1; }
}
.bis-success-{{ block.id }} h3 {
  font-size: 20px;
  font-weight: 800;
  margin: 0 0 8px;
}
.bis-success-{{ block.id }} p {
  font-size: 13px;
  opacity: 0.6;
  margin: 0;
  line-height: 1.5;
}

/* ─── Notify button ───────────────────────────────────────── */
.bis-btn-{{ block.id }} {
  width: 100%;
  padding: 16px;
  background: linear-gradient(135deg, #111 0%, #2d2d2d 100%);
  color: white;
  cursor: pointer;
  border: none;
  border-radius: 12px;
  font-size: 16px;
  font-weight: 700;
  transition: all 0.25s;
  display: none;
  letter-spacing: 0.2px;
  font-family: {{ block.settings.popup_font }};
}
.bis-btn-{{ block.id }}:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(0,0,0,0.2);
}

/* ─── Progress dots ───────────────────────────────────────── */
.bis-dots-{{ block.id }} {
  display: flex;
  justify-content: center;
  gap: 6px;
  margin-top: 20px;
}
.bis-dot-{{ block.id }} {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: rgba(0,0,0,0.15);
  transition: all 0.3s;
}
.bis-dot-{{ block.id }}.active {
  background: #667eea;
  width: 18px;
  border-radius: 3px;
}
</style>

<!-- Notify Button -->
<button class="bis-btn-{{ block.id }}">
  {{ block.settings.button_text | default: 'Notify me when available' }}
</button>

<!-- Overlay -->
<div class="bis-overlay-{{ block.id }}"></div>

<!-- Modal -->
<div class="bis-modal-{{ block.id }}">
  <button class="bis-close-{{ block.id }}" aria-label="Close">✕</button>

  <!-- ── STEP 1: Language Picker ── -->
  <div class="bis-step-{{ block.id }} active" id="bis-step-lang-{{ block.id }}">
    <div class="bis-step-header-{{ block.id }}">
      <span class="bis-icon">🌍</span>
      <h3>{{ block.settings.lang_step_title | default: 'Choose Language' }}</h3>
      <p>{{ block.settings.lang_step_subtitle | default: 'Select your preferred language for notifications' }}</p>
    </div>

    <div class="bis-lang-grid-{{ block.id }}">
      <button class="bis-lang-btn-{{ block.id }}" data-lang="en">
        <span class="bis-flag">🇬🇧</span>
        <span>
          <span class="bis-lang-name">English</span>
          <span class="bis-lang-native">English</span>
        </span>
      </button>
      <button class="bis-lang-btn-{{ block.id }}" data-lang="hi">
        <span class="bis-flag">🇮🇳</span>
        <span>
          <span class="bis-lang-name">Hindi</span>
          <span class="bis-lang-native">हिन्दी</span>
        </span>
      </button>
      <button class="bis-lang-btn-{{ block.id }}" data-lang="fr">
        <span class="bis-flag">🇫🇷</span>
        <span>
          <span class="bis-lang-name">French</span>
          <span class="bis-lang-native">Français</span>
        </span>
      </button>
      <button class="bis-lang-btn-{{ block.id }}" data-lang="de">
        <span class="bis-flag">🇩🇪</span>
        <span>
          <span class="bis-lang-name">German</span>
          <span class="bis-lang-native">Deutsch</span>
        </span>
      </button>
      <button class="bis-lang-btn-{{ block.id }}" data-lang="es">
        <span class="bis-flag">🇪🇸</span>
        <span>
          <span class="bis-lang-name">Spanish</span>
          <span class="bis-lang-native">Español</span>
        </span>
      </button>
      <button class="bis-lang-btn-{{ block.id }}" data-lang="ar">
        <span class="bis-flag">🇸🇦</span>
        <span>
          <span class="bis-lang-name">Arabic</span>
          <span class="bis-lang-native">العربية</span>
        </span>
      </button>
      <button class="bis-lang-btn-{{ block.id }}" data-lang="zh">
        <span class="bis-flag">🇨🇳</span>
        <span>
          <span class="bis-lang-name">Chinese</span>
          <span class="bis-lang-native">中文</span>
        </span>
      </button>
      <button class="bis-lang-btn-{{ block.id }}" data-lang="ja">
        <span class="bis-flag">🇯🇵</span>
        <span>
          <span class="bis-lang-name">Japanese</span>
          <span class="bis-lang-native">日本語</span>
        </span>
      </button>
    </div>

    <div class="bis-dots-{{ block.id }}">
      <div class="bis-dot-{{ block.id }} active"></div>
      <div class="bis-dot-{{ block.id }}"></div>
    </div>
  </div>

  <!-- ── STEP 2: Email Form ── -->
  <div class="bis-step-{{ block.id }}" id="bis-step-email-{{ block.id }}">
    <button class="bis-back-{{ block.id }}" id="bis-back-{{ block.id }}">
      ← <span id="bis-back-text-{{ block.id }}">Back</span>
    </button>

    <div class="bis-step-header-{{ block.id }}">
      <span class="bis-icon">🔔</span>
      <h3 id="bis-email-title-{{ block.id }}">{{ block.settings.headertext | default: 'Get Notified' }}</h3>
      <p id="bis-email-subtitle-{{ block.id }}">{{ block.settings.subheadertext | default: "Enter your email and we'll notify you when back in stock." }}</p>
    </div>

    <div id="bis-lang-badge-wrapper-{{ block.id }}"></div>

    <input
      type="email"
      class="bis-email-{{ block.id }}"
      id="bis-email-input-{{ block.id }}"
      placeholder="{{ block.settings.email_placeholder | default: 'Enter your email' }}"
      required
    >

    <button class="bis-submit-{{ block.id }}" id="bis-submit-{{ block.id }}">
      {{ block.settings.subscribe_text | default: 'Notify Me' }}
    </button>

    <p class="bis-message-{{ block.id }}" id="bis-message-{{ block.id }}"></p>

    <div class="bis-dots-{{ block.id }}">
      <div class="bis-dot-{{ block.id }}"></div>
      <div class="bis-dot-{{ block.id }} active"></div>
    </div>
  </div>

  <!-- ── STEP 3: Success ── -->
  <div class="bis-step-{{ block.id }}" id="bis-step-success-{{ block.id }}">
    <div class="bis-success-{{ block.id }}">
      <span class="bis-success-icon">🎉</span>
      <h3 id="bis-success-title-{{ block.id }}">You're on the list!</h3>
      <p id="bis-success-msg-{{ block.id }}">We'll send you an email the moment this product is back in stock.</p>
    </div>
  </div>
</div>

<script>
(function() {
  const BLOCK_ID   = {{ block.id | json }};
  const btn        = document.querySelector('.bis-btn-' + BLOCK_ID);
  const modal      = document.querySelector('.bis-modal-' + BLOCK_ID);
  const overlay    = document.querySelector('.bis-overlay-' + BLOCK_ID);
