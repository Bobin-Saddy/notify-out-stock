  const backBtn    = document.getElementById('bis-back-' + BLOCK_ID);
  const submitBtn  = document.getElementById('bis-submit-' + BLOCK_ID);
  const emailInput = document.getElementById('bis-email-input-' + BLOCK_ID);
  const messageEl  = document.getElementById('bis-message-' + BLOCK_ID);
  const langBadgeWrapper = document.getElementById('bis-lang-badge-wrapper-' + BLOCK_ID);

  const stepLang    = document.getElementById('bis-step-lang-'    + BLOCK_ID);
