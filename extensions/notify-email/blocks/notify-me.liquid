      invalid:     '请输入有效的邮箱地址。',
      empty:       '请输入您的邮箱。'
    },
    ja: {
      flag: '🇯🇵', name: '日本語',
      title:       '通知を受け取る',
      subtitle:    '在庫が戻り次第、メールでお知らせします。',
      placeholder: 'メールアドレスを入力',
      submit:      '通知する',
      back:        '戻る',
      successTitle:'リストに追加されました！🎉',
      successMsg:  '在庫が戻り次第、メールでお知らせします。',
      alreadyOn:   'すでにウェイティングリストに登録されています！🔔',
      inStock:     'この商品は現在在庫があります！',
      network:     'ネットワークエラーです。再試行してください。',
      server:      'サーバーエラーです。再試行してください。',
      invalid:     '有効なメールアドレスを入力してください。',
      empty:       'メールアドレスを入力してください。'
    }
  };

  let selectedLang = 'en';

  // ─── Variant helpers ──────────────────────────────────────────
  function getSelectedVariantId() {
    const params    = new URLSearchParams(window.location.search);
    const idFromUrl = params.get('variant');
    if (idFromUrl) return parseInt(idFromUrl);
    const selectEl = document.querySelector('select[name="id"], input[name="id"]:checked');
    if (selectEl && selectEl.value) return parseInt(selectEl.value);
    return allVariants[0]?.id ?? null;
  }

  function getSelectedVariant() {
    const id = getSelectedVariantId();
    return id ? (allVariants.find(v => v.id === id) || null) : null;
  }

  function isTrulyOutOfStock(variant) {
    if (!variant) return false;
    if (!variant.inventory_management || variant.inventory_management === 'none') return false;
    if (variant.inventory_policy === 'continue') return false;
    const qty = variant.inventory_quantity;
    if (typeof qty === 'number' && qty <= 0) return true;
    return !variant.available;
  }

  function updateButtonVisibility() {
    const outOfStock = isTrulyOutOfStock(getSelectedVariant());
    btn.style.display = outOfStock ? 'block' : 'none';
    if (!outOfStock && modal.style.display === 'block') closeModal();
  }

  // ─── Step management ──────────────────────────────────────────
  function showStep(step) {
    [stepLang, stepEmail, stepSuccess].forEach(s => {
      s.classList.remove('active');
    });
    step.classList.add('active');
  }

  // ─── Modal open / close ───────────────────────────────────────
  function openModal() {
    if (!isTrulyOutOfStock(getSelectedVariant())) return;
    modal.style.display   = 'block';
    overlay.style.display = 'block';
    emailInput.value      = '';
    messageEl.textContent = '';
    messageEl.className   = 'bis-message-' + BLOCK_ID;
    showStep(stepLang); // Always start at language picker
  }

  function closeModal() {
    modal.style.display   = 'none';
    overlay.style.display = 'none';
  }

  // ─── Apply language to email step ─────────────────────────────
  function applyLanguage(lang) {
    selectedLang = lang;
    const t = TRANSLATIONS[lang] || TRANSLATIONS['en'];

    document.getElementById('bis-email-title-'    + BLOCK_ID).textContent    = t.title;
    document.getElementById('bis-email-subtitle-' + BLOCK_ID).textContent    = t.subtitle;
    document.getElementById('bis-back-text-'      + BLOCK_ID).textContent    = t.back;
    emailInput.placeholder                                                      = t.placeholder;
    submitBtn.textContent                                                        = t.submit;
    messageEl.textContent                                                        = '';

    // RTL support for Arabic
    stepEmail.style.direction = lang === 'ar' ? 'rtl' : 'ltr';

    // Language badge
    langBadgeWrapper.innerHTML = `
      <div class="bis-lang-badge-${BLOCK_ID}">
        <span>${t.flag}</span>
        <span>${t.name}</span>
      </div>`;

    // Success step texts
    document.getElementById('bis-success-title-' + BLOCK_ID).textContent = t.successTitle;
    document.getElementById('bis-success-msg-'   + BLOCK_ID).textContent = t.successMsg;
  }

  // ─── Language button clicks ───────────────────────────────────
  document.querySelectorAll('.bis-lang-btn-' + BLOCK_ID).forEach(function(langBtn) {
    langBtn.addEventListener('click', function() {
      const lang = langBtn.getAttribute('data-lang');
      applyLanguage(lang);
      showStep(stepEmail);
      emailInput.focus();
    });
  });

  // ─── Back button ──────────────────────────────────────────────
  backBtn.addEventListener('click', function() {
    showStep(stepLang);
  });

  // ─── Submit ───────────────────────────────────────────────────
  submitBtn.addEventListener('click', async function() {
    const t     = TRANSLATIONS[selectedLang] || TRANSLATIONS['en'];
    const email = emailInput.value.trim();

    if (!email)                                        { showMsg(t.empty,   true); return; }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email))   { showMsg(t.invalid, true); return; }

    const variant = getSelectedVariant();
    if (!variant)                                       { showMsg('Variant not found', true); return; }
    if (!isTrulyOutOfStock(variant))                    { showMsg(t.inStock, true); setTimeout(closeModal, 2000); return; }

    submitBtn.disabled    = true;
    submitBtn.textContent = '...';

    try {
      const requestData = {
        email,
        variantId:    variant.id.toString(),
        productId:    String({{ product.id | json }}),
        productName:  {{ product.title | json }},
        variantTitle: variant.title || 'Default',
        shop:         {{ shop.permanent_domain | json }},
        currentPrice: variant.price ? (variant.price / 100).toFixed(2) : '0.00',
        language:     selectedLang  // ← sent to server for language-aware emails
      };

      const response = await fetch('/apps/notify-out-stock/proxy/subscribe', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify(requestData)
      });

      const ct = response.headers.get('content-type');
      if (!ct || !ct.includes('application/json')) {
        showMsg(t.server, true);
        return;
      }

      const data = await response.json();

      if (data.success) {
        showStep(stepSuccess);
        setTimeout(closeModal, 3000);
      } else {
        showMsg(data.message || data.error || t.server, !data.success);
      }
    } catch (err) {
      console.error('[BIS]', err);
      showMsg(t.network, true);
    } finally {
      submitBtn.disabled    = false;
      submitBtn.textContent = (TRANSLATIONS[selectedLang] || TRANSLATIONS['en']).submit;
    }
  });

  function showMsg(text, isError) {
    messageEl.textContent = text;
    messageEl.className   = 'bis-message-' + BLOCK_ID + (isError ? ' error' : ' success');
  }

  emailInput.addEventListener('keypress', function(e) {
    if (e.key === 'Enter') { e.preventDefault(); submitBtn.click(); }
  });

  // ─── Open / close handlers ────────────────────────────────────
  btn.addEventListener('click',     openModal);
  closeBtn.addEventListener('click', closeModal);
  overlay.addEventListener('click',  closeModal);

  // ─── Visibility listeners ─────────────────────────────────────
  document.addEventListener('DOMContentLoaded',      updateButtonVisibility);
  document.addEventListener('change', function(e) {
    if (e.target.matches('select[name="id"]') || e.target.matches('input[name="id"]'))
      updateButtonVisibility();
  });
  document.addEventListener('variant:change',        updateButtonVisibility);
  document.addEventListener('variantChange',          updateButtonVisibility);
  document.addEventListener('shopify:section:load',  updateButtonVisibility);
  window.addEventListener('popstate',                updateButtonVisibility);

  let lastVariantId = null;
  setInterval(function() {
    if (modal.style.display === 'block') return;
    const id = getSelectedVariantId();
    if (id !== lastVariantId) { lastVariantId = id; updateButtonVisibility(); }
  }, 400);

})();
</script>

{% schema %}
{
  "name": "Notify Me Button",
  "target": "section",
  "settings": [
    { "type": "text",  "id": "button_text",        "label": "Button Text",               "default": "Notify me when available" },
    { "type": "text",  "id": "lang_step_title",     "label": "Language Step Title",       "default": "Choose Language" },
    { "type": "text",  "id": "lang_step_subtitle",  "label": "Language Step Subtitle",    "default": "Select your preferred language for notifications" },
    { "type": "text",  "id": "headertext",          "label": "Email Step Header",         "default": "Get Notified" },
    { "type": "text",  "id": "subheadertext",       "label": "Email Step Subheader",      "default": "Enter your email and we'll notify you when back in stock." },
    { "type": "text",  "id": "email_placeholder",   "label": "Email Placeholder",         "default": "Enter your email" },
    { "type": "text",  "id": "subscribe_text",      "label": "Subscribe Button Text",     "default": "Notify Me" },
    { "type": "color", "id": "popup_bg_color",      "label": "Popup Background Color",    "default": "#ffffff" },
    { "type": "color", "id": "popup_text_color",    "label": "Popup Text Color",          "default": "#000000" },
    {
      "type": "select",
      "id": "popup_font",
      "label": "Popup Font Family",
      "default": "Inter, sans-serif",
      "options": [
        { "value": "Inter, sans-serif",      "label": "Inter" },
        { "value": "Poppins, sans-serif",    "label": "Poppins" },
        { "value": "Roboto, sans-serif",     "label": "Roboto" },
        { "value": "Montserrat, sans-serif", "label": "Montserrat" }
      ]
    }
  ]
}
{% endschema %}