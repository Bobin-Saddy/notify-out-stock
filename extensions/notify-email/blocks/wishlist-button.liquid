{% comment %}
  Wishlist Button with Email Popup
  File: wishlist-button.liquid
{% endcomment %}

<style>
/* ── Wishlist Button ── */
.wl-btn-{{ block.id }} {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 14px 20px;
  background: transparent;
  border: 2px solid #e5e7eb;
  border-radius: 10px;
  font-size: 15px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.25s;
  width: 100%;
  justify-content: center;
  color: #111;
}

.wl-btn-{{ block.id }}:hover {
  border-color: #ef4444;
  color: #ef4444;
  background: #fff5f5;
}

.wl-btn-{{ block.id }}.wishlisted {
  border-color: #ef4444;
  color: #ef4444;
  background: #fff5f5;
}

.wl-btn-{{ block.id }} svg {
  width: 20px;
  height: 20px;
  transition: all 0.25s;
  flex-shrink: 0;
}

.wl-btn-{{ block.id }}.wishlisted svg {
  fill: #ef4444;
  stroke: #ef4444;
}

/* ── Overlay ── */
.wl-overlay-{{ block.id }} {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  backdrop-filter: blur(4px);
  display: none;
  z-index: 9998;
}

/* ── Modal ── */
.wl-modal-{{ block.id }} {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: calc(100% - 32px);
  max-width: 400px;
  background: #fff;
  border-radius: 16px;
  padding: 28px 24px;
  box-shadow: 0 24px 64px rgba(0,0,0,0.2);
  z-index: 9999;
  display: none;
  animation: wlPop 0.2s ease forwards;
}

@keyframes wlPop {
  from { opacity: 0; transform: translate(-50%, -48%) scale(0.95); }
  to   { opacity: 1; transform: translate(-50%, -50%) scale(1);    }
}

.wl-modal-{{ block.id }} .wl-heart-icon {
  text-align: center;
  font-size: 36px;
  margin-bottom: 12px;
}

.wl-modal-{{ block.id }} h3 {
  margin: 0 0 6px;
  font-size: 20px;
  font-weight: 700;
  text-align: center;
  color: #111;
}

.wl-modal-{{ block.id }} p {
  margin: 0 0 20px;
  font-size: 14px;
  text-align: center;
  color: #6b7280;
}

.wl-modal-close-{{ block.id }} {
  position: absolute;
  top: 14px;
  right: 16px;
  border: none;
  background: none;
  font-size: 20px;
  cursor: pointer;
  color: #9ca3af;
  line-height: 1;
}

.wl-modal-close-{{ block.id }}:hover { color: #111; }

.wl-input-{{ block.id }} {
  width: 100%;
  padding: 13px 14px;
  border: 1.5px solid #e5e7eb;
  border-radius: 10px;
  font-size: 15px;
  margin-bottom: 12px;
  box-sizing: border-box;
  transition: border-color 0.2s;
  outline: none;
}

.wl-input-{{ block.id }}:focus { border-color: #ef4444; }

.wl-save-btn-{{ block.id }} {
  width: 100%;
  padding: 14px;
  background: #ef4444;
  color: #fff;
  border: none;
  border-radius: 10px;
  font-size: 15px;
  font-weight: 700;
  cursor: pointer;
  transition: 0.2s;
}

.wl-save-btn-{{ block.id }}:hover    { background: #dc2626; }
.wl-save-btn-{{ block.id }}:disabled { opacity: 0.6; cursor: not-allowed; }

.wl-msg-{{ block.id }} {
  margin-top: 10px;
  font-size: 13px;
  text-align: center;
}

.wl-msg-{{ block.id }}.success { color: #10b981; }
.wl-msg-{{ block.id }}.error   { color: #ef4444; }
</style>

<!-- Wishlist Button -->
<button class="wl-btn-{{ block.id }}" aria-label="Add to wishlist">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
  </svg>
  <span class="wl-btn-text-{{ block.id }}">{{ block.settings.button_text | default: 'Add to Wishlist' }}</span>
</button>

<!-- Overlay -->
<div class="wl-overlay-{{ block.id }}"></div>

<!-- Email Modal -->
<div class="wl-modal-{{ block.id }}" role="dialog" aria-modal="true">
  <button class="wl-modal-close-{{ block.id }}" aria-label="Close">✕</button>

  <div class="wl-heart-icon">❤️</div>
  <h3>{{ block.settings.modal_title | default: 'Save to Wishlist' }}</h3>
  <p>{{ block.settings.modal_subtitle | default: "Enter your email to save this item and we'll notify you of any price changes." }}</p>

  <input
    type="email"
    class="wl-input-{{ block.id }}"
    placeholder="{{ block.settings.email_placeholder | default: 'Enter your email' }}"
  >

  <button class="wl-save-btn-{{ block.id }}">
    {{ block.settings.save_button_text | default: 'Save to Wishlist' }}
  </button>

  <p class="wl-msg-{{ block.id }}"></p>
</div>

<script>
(function () {
  const BLOCK_ID   = {{ block.id | json }};
  const PRODUCT_ID = String({{ product.id }});
  const STORAGE_KEY = 'wl_' + {{ shop.permanent_domain | json }} + '_' + PRODUCT_ID;

  const btn      = document.querySelector('.wl-btn-'        + BLOCK_ID);
  const btnText  = document.querySelector('.wl-btn-text-'   + BLOCK_ID);
  const overlay  = document.querySelector('.wl-overlay-'    + BLOCK_ID);
  const modal    = document.querySelector('.wl-modal-'      + BLOCK_ID);
  const closeBtn = document.querySelector('.wl-modal-close-'+ BLOCK_ID);
  const input    = document.querySelector('.wl-input-'      + BLOCK_ID);
  const saveBtn  = document.querySelector('.wl-save-btn-'   + BLOCK_ID);
  const msgEl    = document.querySelector('.wl-msg-'        + BLOCK_ID);

  const TEXT_ADD    = {{ block.settings.button_text | default: 'Add to Wishlist' | json }};
  const TEXT_SAVED  = {{ block.settings.button_saved_text | default: 'Wishlisted ✓' | json }};
  const TEXT_SAVE_BTN = {{ block.settings.save_button_text | default: 'Save to Wishlist' | json }};

  // ── State ─────────────────────────────────────────────

  // localStorage se saved email + wishlist status load karo
  function getSavedData() {
    try {
      return JSON.parse(localStorage.getItem(STORAGE_KEY)) || {};
    } catch { return {}; }
  }

  function saveData(data) {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
    } catch {}
  }

  function isWishlisted() {
    return getSavedData().wishlisted === true;
  }

  function getSavedEmail() {
    return getSavedData().email || '';
  }

  // ── UI Update ─────────────────────────────────────────

  function setWishlistedUI(state) {
    if (state) {
      btn.classList.add('wishlisted');
      btnText.textContent = TEXT_SAVED;
    } else {
      btn.classList.remove('wishlisted');
      btnText.textContent = TEXT_ADD;
    }
  }

  function showMsg(text, isError = false) {
    msgEl.textContent = text;
    msgEl.className   = 'wl-msg-' + BLOCK_ID + (isError ? ' error' : ' success');
  }

  function openModal() {
    input.value = getSavedEmail(); // Pehla email pre-fill karo
    msgEl.textContent = '';
    msgEl.className   = 'wl-msg-' + BLOCK_ID;
    modal.style.display   = 'block';
    overlay.style.display = 'block';
    setTimeout(() => input.focus(), 100);
  }

  function closeModal() {
    modal.style.display   = 'none';
    overlay.style.display = 'none';
  }

  // ── API Call ──────────────────────────────────────────

  async function callWishlistAPI(email, action) {
    const allVariants = {{ product.variants | json }};
    const urlParam    = new URLSearchParams(window.location.search).get('variant');
    const variantId   = urlParam
      ? parseInt(urlParam)
      : (allVariants.find(v => v.available) || allVariants[0])?.id;
    const variant     = allVariants.find(v => v.id === variantId) || allVariants[0];

    const payload = {
      email,
      action,
      shop:         {{ shop.permanent_domain | json }},
      productId:    PRODUCT_ID,
      variantId:    String(variant?.id || ''),
      productTitle: {{ product.title | json }},
      variantTitle: variant?.title || 'Default',
      productImage: {{ product.featured_image | img_url: '400x' | json }},
      productHandle: {{ product.handle | json }},
      price:        variant ? (variant.price / 100).toFixed(2) : '0.00',
    };

    const res  = await fetch('/apps/notify-out-stock/proxy/wishlist-add', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify(payload),
    });

    if (!res.headers.get('content-type')?.includes('application/json')) {
      throw new Error('Server error');
    }
    return res.json();
  }

  // ── Button Click ──────────────────────────────────────

  btn.onclick = async function () {
    // ✅ Agar already wishlisted hai → UNWISHLIST (email chahiye, localStorage se lo)
    if (isWishlisted()) {
      const email = getSavedEmail();
      if (!email) {
        // email nahi pata → modal kholo phir se
        openModal();
        return;
      }

      btn.disabled = true;
      try {
        const data = await callWishlistAPI(email, 'remove');
        if (data.success) {
          saveData({ email, wishlisted: false }); // email yaad rakho, status false
          setWishlistedUI(false);
        }
      } catch (e) {
        console.error('Unwishlist error:', e);
      } finally {
        btn.disabled = false;
      }
      return;
    }

    // ✅ Wishlisted nahi → modal kholo
    openModal();
  };

  closeBtn.onclick = closeModal;
  overlay.onclick  = closeModal;

  // ── Save Button ───────────────────────────────────────

  saveBtn.onclick = async function () {
    const email = input.value.trim();

    if (!email) { showMsg('Please enter your email', true); return; }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      showMsg('Please enter a valid email', true);
      return;
    }

    saveBtn.disabled    = true;
    saveBtn.textContent = 'Saving...';

    try {
      const data = await callWishlistAPI(email, 'add');

      if (data.success) {
        // ✅ localStorage mein save karo
        saveData({ email, wishlisted: true });
        setWishlistedUI(true);
        showMsg('❤️ Saved to your wishlist!', false);
        setTimeout(closeModal, 1500);
      } else {
        showMsg(data.error || 'Something went wrong', true);
      }
    } catch (err) {
      console.error('Wishlist error:', err);
      showMsg('Network error. Please try again.', true);
    } finally {
      saveBtn.disabled    = false;
      saveBtn.textContent = TEXT_SAVE_BTN;
    }
  };

  input.addEventListener('keypress', function (e) {
    if (e.key === 'Enter') { e.preventDefault(); saveBtn.click(); }
  });

  // ── Init: page load pe state restore karo ────────────
  document.addEventListener('DOMContentLoaded', function () {
    setWishlistedUI(isWishlisted());
  });

})();
</script>

{% schema %}
{
  "name": "Wishlist Button",
  "target": "section",
  "settings": [
    { "type": "text", "id": "button_text",       "label": "Button Text",             "default": "Add to Wishlist"     },
    { "type": "text", "id": "button_saved_text", "label": "Button Wishlisted Text",  "default": "Wishlisted ✓"        },
    { "type": "text", "id": "modal_title",       "label": "Modal Title",             "default": "Save to Wishlist"    },
    { "type": "text", "id": "modal_subtitle",    "label": "Modal Subtitle",          "default": "Enter your email to save this item."  },
    { "type": "text", "id": "email_placeholder", "label": "Email Placeholder",       "default": "Enter your email"    },
    { "type": "text", "id": "save_button_text",  "label": "Save Button Text",        "default": "Save to Wishlist"    }
  ]
}
{% endschema %}